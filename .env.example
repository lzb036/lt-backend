# MySQL is required. The backend will create the database if the MySQL account has permission.
LT_DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/lt_collector?charset=utf8mb4

LT_DATABASE_AUTO_CREATE=true
LT_DATABASE_ECHO=false
LT_SESSION_COOKIE_NAME=lt_session
LT_SESSION_COOKIE_SECURE=false
LT_INITIAL_SUPERADMIN_USERNAME=superadmin
LT_INITIAL_SUPERADMIN_PASSWORD=123456

# Default values written to Rakuten inventory after a new item is listed.
# Set delivery time IDs to 0 to omit operationLeadTime, matching existing shop inventory records.
LT_RAKUTEN_DEFAULT_INVENTORY_QUANTITY=1000
LT_RAKUTEN_DEFAULT_NORMAL_DELIVERY_TIME_ID=0
LT_RAKUTEN_DEFAULT_BACK_ORDER_DELIVERY_TIME_ID=0
