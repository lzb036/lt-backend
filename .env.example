# MySQL is required. The backend will create the database if the MySQL account has permission.
LT_DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/lt_collector?charset=utf8mb4

LT_DATABASE_AUTO_CREATE=true
LT_DATABASE_ECHO=false
LT_DATABASE_POOL_SIZE=10
LT_DATABASE_MAX_OVERFLOW=20
LT_DATABASE_POOL_TIMEOUT=30

LT_MAX_RUNNING_CRAWL_TASKS_PER_USER=2
LT_MAX_RUNNING_SYNC_TASKS_PER_USER=2
LT_MAX_RUNNING_LISTING_TASKS_PER_USER=1

LT_SESSION_COOKIE_NAME=lt_session
LT_SESSION_COOKIE_SECURE=false
LT_SESSION_DURATION_SECONDS=604800
LT_LOGIN_MAX_FAILED_ATTEMPTS=5
LT_LOGIN_LOCKOUT_SECONDS=900
LT_INITIAL_SUPERADMIN_USERNAME=superadmin
LT_INITIAL_SUPERADMIN_PASSWORD=123456

LT_CRAWLER_MAX_RANKING_PAGES=200
LT_CRAWLER_BATCH_SIZE=10
LT_CRAWLER_BATCH_PAUSE_SECONDS=3
LT_PRODUCT_IMAGE_DRAFT_RETENTION_DAYS=7

# thread keeps the old in-process behavior. Use redis to dispatch jobs to an RQ worker.
LT_TASK_QUEUE_MODE=thread
LT_REDIS_URL=redis://127.0.0.1:6379/0
LT_TASK_QUEUE_NAME=lt-tasks
LT_TASK_QUEUE_CRAWL_NAME=lt-tasks-crawl
LT_TASK_QUEUE_SYNC_NAME=lt-tasks-sync
LT_TASK_QUEUE_LISTING_NAME=lt-tasks-listing
LT_TASK_QUEUE_SCHEDULE_NAME=lt-tasks-schedule
LT_TASK_QUEUE_JOB_TIMEOUT_SECONDS=3600
LT_TASK_QUEUE_RESULT_TTL_SECONDS=86400
LT_TASK_QUEUE_FAILURE_TTL_SECONDS=604800

# Worker examples:
#   python worker.py                 # listen to all queues, including the legacy LT_TASK_QUEUE_NAME
#   python worker.py listing         # listen to only LT_TASK_QUEUE_LISTING_NAME
#   python worker.py crawl,sync      # listen to crawl and sync queues

# Default values written to Rakuten inventory after a new item is listed.
# Set delivery time IDs to 0 to omit operationLeadTime, matching existing shop inventory records.
LT_RAKUTEN_DEFAULT_INVENTORY_QUANTITY=1000
LT_RAKUTEN_DEFAULT_NORMAL_DELIVERY_TIME_ID=0
LT_RAKUTEN_DEFAULT_BACK_ORDER_DELIVERY_TIME_ID=0
